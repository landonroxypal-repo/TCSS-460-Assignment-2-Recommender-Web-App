<!DOCTYPE html>
<html lang="en">
<%- include("partials/header") %>

<body class="min-h-screen bg-slate-950 text-slate-100">
  <%- include("partials/nav") %>

  <main class="max-w-5xl mx-auto px-6 py-10">
    <section class="rounded-xl shadow border p-8 bg-slate-900 border-slate-700">
      <h1 class="text-3xl font-bold mb-3">PixelPicks Tool</h1>

      <hr class="my-6 border-1 border-slate-700">

      <h1 class="text-xl font-bold mb-3 text-green-400 uppercase">Step 1.)</h1>

      <p class="mb-6 text-slate-300">
        Enter your preference for the following aspects of games below.
        For each category enter an integer from 0 to 10 where 0 is the
        lowest, and 10 is the highest.
      </p>

      <form action="/tool/results" method="POST" class="space-y-6">
        <section class="grid gap-4 md:grid-cols-2">
          <% data.criteria.forEach(function(criterion) { %>
            <div class="border rounded-lg p-4 border-slate-600 bg-slate-800">
              <label for="<%= criterion.id %>" class="block font-semibold mb-1">
                <%= criterion.name %>
              </label>

              <p class="text-sm mb-2 text-slate-400">
                <%= criterion.description %>
              </p>

              <input
                type="number"
                id="<%= criterion.id %>"
                name="<%= criterion.id %>"
                min="0"
                max="10"
                value="1"
                class="w-full border rounded-lg px-3 py-2 bg-slate-800 border-slate-600 text-white">
            </div>
          <% }); %>
        </section>

        <hr class="my-6 border-1 border-slate-700">

        <section>
          <h1 class="text-xl font-bold mb-3 text-green-400 uppercase">Step 2.)</h1>

          <p class="mb-6 text-slate-300">
            Choose a scoring method to rank all games by.
          </p>

          <div class="flex flex-row gap-4">
            <label class="flex-1 block border rounded-lg p-4 border-slate-600 bg-slate-800 ">
              <input type="radio" name="method" value="weighted-sum" checked>
                Weighted Sum
                <p class="text-slate-300">
                  Rewards high criteria scores.
                </p>
            </label>

            <label class="flex-1 block border rounded-lg p-4 border-slate-600 bg-slate-800">
              <input type="radio" name="method" value="weighted-product">
              Weighted Product
                <p class="text-slate-300">
                  Punishes low criteria scores.
                </p>
            </label>
          </div>
        </section>

        <hr class="my-6 border-1 border-slate-700">

        <div class="flex gap-3">
          <button type="submit" class="text-white font-semibold px-5 py-3 rounded-lg bg-green-600 hover:bg-green-700">
            Rank Games
          </button>

          <button type="reset" class="border font-semibold px-5 py-3 rounded-lg border-white hover:bg-slate-800 text-white">
            Reset
          </button>
        </div>
      </form>
    </section>
  </main>

  <%- include("partials/footer") %>
</body>
</html>
